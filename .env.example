# Required — pipeline fails at startup if absent
ANTHROPIC_API_KEY=sk-ant-REPLACE-WITH-YOUR-KEY

# Optional paths (defaults shown)
DATA_DIR=data
OUTPUT_DIR=outputs
DOCS_DIR=docs

# Tunables
LOG_LEVEL=INFO
MAX_STUDENTS_PER_LLM_CALL=10
LLM_MAX_WORKERS=5          # campuses processed in parallel (reduce if hitting rate limits)
TIMEOUT_SECONDS=10         # fail fast; template fallback kicks in after 1 retry
ANTHROPIC_MODEL=claude-haiku-4-5  # faster + cheaper; switch to claude-sonnet-4-6 for quality

# Risk thresholds (override defaults from src/config.py)
RISK_THRESHOLD_CRITICAL=75
RISK_THRESHOLD_HIGH=50
